# ===================================================
# Scraply AI Agent Environment Configuration
# ===================================================
# Copy this file to .env and fill in the values

# ---------------------------------------------------
# DATABASE (Read-Only Access)
# ---------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=scraply
DB_USER=scraply_agent
DB_PASSWORD=your_agent_db_password

# ---------------------------------------------------
# REDIS (Queue Operations)
# ---------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_SSL=false

# ---------------------------------------------------
# BACKEND API
# ---------------------------------------------------
API_BASE_URL=http://localhost:8080
API_TIMEOUT=30

# Agent Authentication (must match backend secrets.properties)
AGENT_ACCESS_KEY=your_agent_access_key
AGENT_SECRET_KEY=your_agent_secret_key

# ---------------------------------------------------
# AI / LLM CONFIGURATION
# ---------------------------------------------------
# Get your API key from https://console.groq.com/
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048

# ---------------------------------------------------
# VISION / IMAGE ANALYSIS
# ---------------------------------------------------
# Enable/disable image analysis
VISION_ENABLED=true

# Optional Gemini key (if unset, image analysis uses Groq vision fallback)
# Get your API key from https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key

# Gemini vision model
VISION_MODEL=gemini-2.0-flash

# Groq vision model used when Gemini key is not configured
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Optional comma-separated fallback models (tried in order)
GROQ_VISION_FALLBACK_MODELS=meta-llama/llama-4-maverick-17b-128e-instruct

# Maximum image size in MB (larger images will be skipped)
VISION_MAX_IMAGE_SIZE_MB=4.0

# ---------------------------------------------------
# AGENT CONFIGURATION
# ---------------------------------------------------
# The agent's user ID in the database (must have AGENT role)
AGENT_ID=USR_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Processing configuration
POLL_INTERVAL=5.0
RETRY_ATTEMPTS=3
RETRY_DELAY=2.0

# Duplicate detection thresholds
DUPLICATE_DISTANCE_KM=0.5
DUPLICATE_TIME_HOURS=24

# Concurrency (for future use)
MAX_CONCURRENT_TASKS=5
